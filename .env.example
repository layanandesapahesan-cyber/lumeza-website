# ===========================
# DATABASE CONFIGURATION
# ===========================
DATABASE_URL="file:./prisma/dev.db"

# ===========================
# EMAIL SERVICE (RESEND)
# ===========================
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Email yang akan terlihat di sender
NEXT_PUBLIC_FROM_EMAIL=noreply@lumeza.com

# Email untuk menerima contact form
NEXT_PUBLIC_CONTACT_EMAIL=hello@lumeza.com
CONTACT_FORM_RECIPIENT_EMAIL=hello@lumeza.com

# ===========================
# WEBSITE CONFIGURATION
# ===========================
# Base URL untuk production
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ===========================
# ANALYTICS (OPTIONAL)
# ===========================
# Google Analytics - dapatkan dari https://analytics.google.com
# NEXT_PUBLIC_GA_ID=G_XXXXXXXXXX

# Vercel Analytics - gunakan salah satu (GA atau Vercel, tidak keduanya)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=true

# ===========================
# DEVELOPMENT FLAGS
# ===========================
# NODE_ENV akan otomatis set oleh Next.js (development/production)
# DEBUG=false
